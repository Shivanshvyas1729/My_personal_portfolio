# === CMS & PRODUCTION AUTH ===
# Required for production commits (GitHub Mode) - Get this from GitHub Developer Settings -> Personal Access Tokens (Classic or Fine-grained with repo access)
GITHUB_TOKEN=your_github_pat_here

# Master admin toggle for Unified Dashboard
ADMIN_PASSWORD=your_admin_password_here

# Access to restricted resources
SECRET_PASSWORD=your_secret_password_here

# Access to Blog CMS
BLOG_PASSWORD=your_blog_password_here

# Access to YAML content editing
EDITOR_PASSWORD=your_editor_password_here

# === COMMUNICATIONS (EmailJS) ===
# Create an account at emailjs.com to get these
# Service ID from EmailJS dashboard
EMAILJS_SERVICE_ID=your_emailjs_service_id_here

# Template ID for contact forms
EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here

# Public Key from EmailJS account settings
EMAIL_API_KEY=your_emailjs_public_key_here

# === AI CHATBOT (Optional) ===
# Type of API to use for chatbot (e.g., huggingface, openai)
# VITE_API_TYPE=huggingface

# The endpoint for the AI model
# VITE_API_CHAT_URL=https://api-inference.huggingface.co/models/mistralai/Mistral-7B-Instruct-v0.1

# API Key for the chatbot provider
# VITE_HF_API_KEY=your_huggingface_token_here
