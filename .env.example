# ============================================================
# ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values.
# Priority order for GitHub/repo config:
#   1. Values in this file (.env)        ← highest priority
#   2. config.yaml in project root       ← fallback YAML
#   3. Deployment platform variables     ← Vercel/Netlify
#   4. git remote auto-detect            ← last resort
# ============================================================

# === GITHUB REPOSITORY (Priority 1) ===
GITHUB_OWNER=YourGitHubUsername
GITHUB_REPO=YourRepoName
GITHUB_BRANCH=main

# === GITHUB AUTH TOKEN ===
# Required in production for CMS write access (GitHub API)
GITHUB_TOKEN=github_pat_...

# === CMS MODE ===
# "github" = write directly to GitHub (production)
# "local"  = save files locally (development)
CMS_MODE=github

# === ADMIN CREDENTIALS ===
# These are read fresh from disk on every API call — no restart needed
ADMIN_USERNAME=YourAdminUsername
ADMIN_PASSWORD=your_secure_password

# === COMMUNICATIONS (EmailJS) ===
EMAILJS_SERVICE_ID=your_id
EMAILJS_TEMPLATE_ID=your_template
EMAIL_API_KEY=your_public_key

# === MEDIA UPLOADS (Cloudinary) ===
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
